# ===== Langfuse Cloud（trace） =====
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 前端用的 Langfuse Project ID（用于生成 trace 跳转链接）
NEXT_PUBLIC_LANGFUSE_PROJECT_ID=cmqnxbcncxxxxxxxxxxxxxxxxxx

# ===== Neon（业务 PG） =====
DATABASE_URL=postgresql://user:password@host:port/db?sslmode=require

# ===== 腾讯云 COS（对象存储） =====
# 详见 infra/CLOUD_SETUP.md
TENCENT_SECRET_ID=...
TENCENT_SECRET_KEY=...
TENCENT_REGION=ap-shanghai
TENCENT_BUCKET=miao-agents-<APPID>
COS_ENDPOINT=https://cos.ap-shanghai.myqcloud.com

# ===== DashScope（LLM provider，OpenAI 兼容） =====
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# ===== Secret Encryption（Fernet，用于加密 Provider API Key） =====
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
