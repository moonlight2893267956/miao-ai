# ===== miao-ai 本地开发凭证 =====
#
# 使用方法：
#   1. cp .env.local.example .env.local
#   2. 在本地 MySQL 创建 miao_ai 库和 miao 用户（见下方说明）
#   3. 把凭证粘贴到 .env.local 对应位置
#
# 加载顺序（本地启动时）：
#   1. scripts/start-all.sh 优先 source .env.local 注入 bash 进程
#   2. backend/app/config.py 用 pydantic-settings 读 .env.local（覆盖根 .env）
#   3. 透传给 agent 子进程（LANGFUSE_* 走 os.environ）
#
# 注意：
#   - .env.local 已在 .gitignore，不会被提交
#   - 根 .env 是生产凭证，不要复制到这里
#   - 没有 .env.local 时本地会回退到根 .env，会污染生产数据（脚本会打 warning）

# ===== 本地 MySQL =====
# 与 miao-toolbox 共用同一 MySQL 实例，库名不同
# 创建库和用户：
#   CREATE DATABASE IF NOT EXISTS miao_ai CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#   CREATE USER IF NOT EXISTS 'miao'@'%' IDENTIFIED BY 'miao_dev';
#   GRANT ALL PRIVILEGES ON miao_ai.* TO 'miao'@'%';
#   FLUSH PRIVILEGES;
DATABASE_URL=mysql+aiomysql://miao:miao_dev@localhost:3306/miao_ai?charset=utf8mb4

# ===== 本地 Langfuse =====
# 在 https://cloud.langfuse.com/ 登录后：
#   1. 创建一个新 project（建议名 miao-ai-dev，跟生产 project 区分）
#   2. 切到 miao-ai-dev project → Settings → API Keys → Create new key
#   3. 复制 Public Key / Secret Key / Host 到下面
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ===== 本地 DashScope（可选，不填则用根 .env 的值） =====
# 建议：去 https://dashscope.console.aliyun.com/apiKey 单独建一个 dev key
# 方便做配额隔离
# DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_MODEL=qwen-plus

# ===== 本地 Secret Encryption（Fernet，可选） =====
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：跟生产的 ENCRYPTION_KEY 不同 → 重新创建 agent 时 Provider API Key 解密会失败
# 推荐跟生产用同一个，或者在本地新建 agent 时用本地 key 重新加密
# ENCRYPTION_KEY=

# ===== 腾讯云 COS（可选，不填则用根 .env 的值） =====
# 如果要完全隔离，可以建一个 miao-ai-dev bucket
# TENCENT_SECRET_ID=...
# TENCENT_SECRET_KEY=...
# TENCENT_REGION=ap-shanghai
# TENCENT_BUCKET=miao-agents-dev
# COS_ENDPOINT=https://cos.ap-shanghai.myqcloud.com
